---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Article-Tool — 本地优先的学术投稿与研究资料工作台',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: '下载软件',
        href: 'https://pan.baidu.com/s/1JqpgmT9Wpub-Bl-Bhh27uQ?pwd=x44v',
        target: '_blank',
        icon: 'tabler:download',
      },
    ]}
    image={{ src: '~/assets/images/软件主页面.jpg', alt: 'Article-Tool 软件主页面截图' }}
  >
    <Fragment slot="title">
      <span class="block">Article-Tool</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="block text-lg leading-8 text-slate-600 dark:text-slate-300 md:text-xl">
        为解决复杂而细碎的学术管理需求而设计的
        <span class="font-semibold text-accent dark:text-blue-200">本地化软件</span>。
      </span>
      <span class="mt-4 block text-base leading-7 text-slate-600 dark:text-slate-300 md:text-lg">
        它不是简单的期刊表格，也不是单纯的待办清单，而是把
        <span class="font-semibold text-gray-950 dark:text-white"
          >期刊库、稿件库、已刊论文库、学术会议、基金项目、日程、AI 报告、附件、备份、个性化设置</span
        >
        等能力整合在一起的综合工作台。
      </span>
      <span class="mt-4 block text-base leading-7 text-slate-600 dark:text-slate-300 md:text-lg">
        它以研究者的实际工作流为中心，将
        <span class="font-semibold text-accent dark:text-blue-200">选题、写作、投稿、审稿、转投、发表、归档、复盘</span>
        纳入同一个系统，让学术生产过程变得更加清晰、连续和可追踪。
      </span>
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="限时优惠:" description="Article-Tool 买断早鸟价 39.9 元，1.7.0 版本后计划恢复至 69.9 元。" />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    tagline="六大亮点"
    title="软件功能"
    subtitle="围绕研究者从选题、写作、投稿到发表归档的真实流程，把分散的信息、任务和资料收束到同一个本地工作台。"
    items={[
      {
        title: '日程系统',
        description: `
          <span class="block">日程系统是软件的时间管理中心，以月历视图展示任务，并在工作区显示选中日期的具体任务列表。</span>
          <span class="mt-2 block">你可以直接为某一天添加任务，也可以从期刊、稿件、已刊论文、学术会议或基金项目详情页创建关联事项。</span>
        `,
        icon: 'tabler:calendar-event',
      },
      {
        title: '期刊库',
        description: `
          <span class="block">期刊库用于保存、整理、评估和筛选可投期刊，是投稿决策前最重要的资料库之一。</span>
          <span class="mt-2 block">默认字段覆盖主办单位、投稿情况、刊物级别、收录情况、研究方向、刊物评价、刊期、相关链接和投稿难度等信息。</span>
        `,
        icon: 'tabler:books',
      },
      {
        title: '稿件库',
        description: `
          <span class="block">稿件库用于管理正在构思、写作、打磨、待投稿、投稿中或已发表的论文。</span>
          <span class="mt-2 block">稿件详情页分为稿件属性、投稿建议、投稿流程和内容块，分别处理结构化字段、期刊匹配、投稿记录和写作资料。</span>
          <span class="mt-2 block">正文资料、写作计划、摘要、修改意见和参考线索都可以围绕同一篇稿件沉淀下来。</span>
        `,
        icon: 'tabler:file-pencil',
      },
      {
        title: '已刊论文库',
        description: `
          <span class="block">已刊论文库用于管理已经发表、待见刊、校样或已收录的论文，不只是一个普通成果表。</span>
          <span class="mt-2 block">它既保存「见刊属性」，也可以保留「稿件属性」。稿件转入已刊论文库时，系统会创建原稿快照。</span>
          <span class="mt-2 block">论文发表后，你仍然可以追溯写作阶段的关键词、目标刊物、优先级、字数、流程记录和内容块。</span>
        `,
        icon: 'tabler:archive',
      },
      {
        title: '学术会议',
        description: `
          <span class="block">学术会议模块用于记录你参与过的会议、论坛、报告和学术交流活动。</span>
          <span class="mt-2 block">它可以与期刊库、稿件库、已刊论文库等对象联动，让会议经历不再散落在零碎笔记里。</span>
        `,
        icon: 'tabler:presentation',
      },
      {
        title: '基金项目',
        description: `
          <span class="block">基金项目模块可以与其他系统联动，集中管理项目从申报到成果归集的全过程。</span>
          <span class="mt-2 block">内置申报记录、立项信息、经费管理、进度节点、成果归集等分页面，帮助你完整记录项目情况。</span>
        `,
        icon: 'tabler:building-bank',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="贴合投稿判断的期刊库"
    title="把零散期刊信息整理成可比较、可追踪、可复用的投稿资产"
    items={[
      {
        title: '结构化期刊档案',
        description:
          '用自定义字段记录主办单位、刊物级别、收录情况、研究方向、刊期、链接、投稿难度与个人评价，让每一本期刊都有清楚的资料卡。',
        icon: 'tabler:book-2',
      },
      {
        title: '关联投稿记录',
        description:
          '所有投向该期刊的稿件、审稿状态、返修记录与转投路径都会自动汇总，方便你回看历史经验，不再重复踩坑。',
        icon: 'tabler:history',
      },
      {
        title: '投稿适配分析',
        description:
          '结合本地记录和 AI 建议，分析期刊偏好、选题匹配度和潜在风险，帮助你更快判断一篇稿件是否值得投向这里。',
        icon: 'tabler:target-arrow',
      },
    ]}
    image={{
      src: '~/assets/images/期刊库 某对象.jpg',
      alt: 'Article-Tool 期刊库详情页面截图',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">期刊库详情页</h3>
      <p class="text-muted dark:text-slate-400">
        围绕一本期刊整理投稿判断所需的全部材料，把刊物属性、研究方向、投稿经验和个人评价放在同一个上下文里。
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: '稿件属性',
        description:
          '记录题目、关键词、研究方向、优先级、字数、状态、目标刊物等核心信息，让每一篇论文都有稳定、可回看的资料页。',
        icon: 'tabler:file-description',
      },
      {
        title: '投稿建议',
        description:
          '结合期刊库资料、本地经验和 AI 辅助分析，为稿件筛选可投方向，帮助你比较适配度、投稿风险和备选路径。',
        icon: 'tabler:target-arrow',
      },
      {
        title: '投稿流程',
        description: '把投稿、退稿、返修、转投、录用等关键节点按时间线记录下来，让一次投稿经历可以被追踪、复盘和复用。',
        icon: 'tabler:route',
      },
    ]}
    image={{
      src: '~/assets/images/稿件库 某对象.jpg',
      alt: 'Article-Tool 稿件库详情页面截图',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">稿件库详情页</h3>
      <p class="text-muted dark:text-slate-400">
        围绕一篇论文组织全部材料，把构思、写作、投稿和修改过程放在同一个上下文里。
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: '见刊属性',
        description: '记录刊物、卷期、页码、DOI、收录情况、见刊时间等发表信息，形成稳定的成果档案。',
        icon: 'tabler:archive',
      },
      {
        title: '稿件属性',
        description: '从稿件库转入已刊论文库时保留原稿快照，发表之后仍然可以回看当时的关键词、目标刊物和修改线索。',
        icon: 'tabler:file-description',
      },
      {
        title: '成果归档',
        description: '把附件、校样、发表链接、复盘记录与后续成果关联起来，让论文不再发表后就失去上下文。',
        icon: 'tabler:folders',
      },
      {
        title: '长期复盘',
        description: '沉淀不同期刊、选题和投稿策略的结果，帮助你在下一次投稿前更快判断方向。',
        icon: 'tabler:history',
      },
    ]}
    image={{
      src: '~/assets/images/已刊论文库 某对象.jpg',
      alt: 'Article-Tool 已刊论文库详情页面截图',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">已刊论文库详情页</h3>
      <p class="text-muted dark:text-slate-400">
        发表不是资料管理的终点，Article-Tool 会把成果信息和写作投稿阶段的上下文继续保留下来。
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    id="workflow"
    tagline="工作流"
    title="从选题到归档，把学术生产过程连成一条线"
    subtitle="Article-Tool 的重点不是让你多填表，而是让每一次判断、投稿、修改和发表都有位置可放、有线索可查。"
    items={[
      {
        title: '对象底座',
        description:
          '期刊库、稿件库、已刊论文库、学术会议和基金项目共同构成资料底座，让研究对象不再散落在表格、文件夹和聊天记录里。',
        icon: 'tabler:database',
      },
      {
        title: '稿件主线',
        description: '围绕一篇稿件记录选题、写作、选刊、投稿、审稿、转投和发表，把关键判断放回同一个上下文。',
        icon: 'tabler:file-pencil',
      },
      {
        title: '节点调度',
        description: '审稿期限、返修计划、会议日期、基金节点都能进入日程系统，重要事项不再只停留在脑子里。',
        icon: 'tabler:calendar-event',
      },
      {
        title: '成果沉淀',
        description: '发表信息、原稿快照、附件、会议反馈、项目成果和复盘记录都能沉淀下来，为下一次选题与投稿提供经验。',
        icon: 'tabler:archive',
      },
    ]}
  >
    <Fragment slot="image">
      <div
        class="overflow-hidden rounded-md border border-slate-200 bg-white shadow-lg shadow-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:shadow-none"
      >
        <div class="border-b border-slate-200 bg-slate-50 px-5 py-4 dark:border-slate-700 dark:bg-slate-800/70">
          <p class="text-sm font-semibold uppercase tracking-wide text-accent dark:text-blue-300">
            Article-Tool Workflow
          </p>
          <h3 class="mt-1 text-xl font-bold text-slate-950 dark:text-white">软件工作流</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
            将选题、写作、投稿、审稿、转投、发表、归档、复盘等过程纳入同一个系统中，让学术生产过程变得更加清晰、连续和可追踪。
          </p>
        </div>

        <div class="px-5 py-5">
          <div class="space-y-3">
            {
              [
                ['01', '选题 / 立项', '从想法、会议反馈或基金任务中形成可推进题目', ['稿件库', '学术会议', '基金项目']],
                ['02', '写作 / 材料', '把提纲、摘要、正文资料和附件沉淀到同一篇稿件下', ['稿件库', '附件']],
                ['03', '选刊 / 投稿', '用期刊库判断适配度，记录目标刊物与提交动作', ['期刊库', '投稿流程']],
                ['04', '审稿 / 返修', '把审稿意见、修改计划和转投记录放回时间线', ['稿件库', '日程']],
                ['05', '会议 / 交流', '记录参会、报告、反馈和可能转化为论文的线索', ['学术会议', '日程']],
                ['06', '基金 / 项目', '管理申报、立项、进度节点与成果归集', ['基金项目', '日程']],
                ['07', '发表 / 归档', '保留发表信息、原稿快照、附件和复盘经验', ['已刊论文库', '备份']],
              ].map(([step, title, detail, modules], index, list) => (
                <div class="relative flex gap-3">
                  {index !== list.length - 1 && (
                    <div class="absolute left-5 top-10 h-[calc(100%-1.25rem)] w-px bg-slate-200 dark:bg-slate-700" />
                  )}
                  <div class="relative z-10 flex size-10 shrink-0 items-center justify-center rounded-full border border-blue-200 bg-blue-50 text-xs font-bold text-blue-700 dark:border-blue-500/40 dark:bg-blue-500/15 dark:text-blue-200">
                    {step}
                  </div>
                  <div class="min-w-0 flex-1 rounded-md border border-slate-200 bg-white px-4 py-3 dark:border-slate-700 dark:bg-slate-950/40">
                    <div class="flex flex-wrap items-baseline justify-between gap-2">
                      <p class="font-semibold text-slate-950 dark:text-white">{title}</p>
                      <p class="text-xs text-slate-500 dark:text-slate-400">可追踪</p>
                    </div>
                    <p class="mt-1 text-sm leading-6 text-slate-600 dark:text-slate-300">{detail}</p>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {(modules as string[]).map((module) => (
                        <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
                          {module}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              ))
            }
          </div>

          <div
            class="mt-5 grid grid-cols-2 overflow-hidden rounded-md border border-slate-200 text-center dark:border-slate-700 sm:grid-cols-4"
          >
            <div
              class="border-r border-b border-slate-200 bg-slate-50 px-3 py-3 dark:border-slate-700 dark:bg-slate-800/60 sm:border-b-0"
            >
              <p class="text-xs text-slate-500 dark:text-slate-400">核心对象</p>
              <p class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">稿件库</p>
            </div>
            <div
              class="border-b border-slate-200 bg-slate-50 px-3 py-3 dark:border-slate-700 dark:bg-slate-800/60 sm:border-r sm:border-b-0"
            >
              <p class="text-xs text-slate-500 dark:text-slate-400">判断依据</p>
              <p class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">期刊库</p>
            </div>
            <div class="border-r border-slate-200 bg-slate-50 px-3 py-3 dark:border-slate-700 dark:bg-slate-800/60">
              <p class="text-xs text-slate-500 dark:text-slate-400">外部节点</p>
              <p class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">会议 / 基金</p>
            </div>
            <div class="bg-slate-50 px-3 py-3 dark:bg-slate-800/60">
              <p class="text-xs text-slate-500 dark:text-slate-400">成果沉淀</p>
              <p class="mt-1 text-sm font-semibold text-slate-900 dark:text-white">已刊论文库</p>
            </div>
          </div>
        </div>
      </div>
    </Fragment>
  </Steps>

  <!-- Features2 Widget ************** -->

  <Features2
    id="details"
    title="贴心、方便而专注，也足够自定义"
    subtitle="它不是为了堆功能，而是把研究者长期会遇到的细碎需求收纳好：少切换、少遗忘、少重复，让资料管理真正服务写作和投稿。"
    tagline="细节能力"
    items={[
      {
        title: '本地优先',
        description: '核心资料保存在自己的电脑中，适合管理尚未发表的选题、稿件、附件和投稿记录。',
        icon: 'tabler:shield-lock',
      },
      {
        title: '字段可配置',
        description: '期刊、稿件、成果、会议和基金项目都可以围绕你的习惯调整字段、分类和记录方式。',
        icon: 'tabler:adjustments-horizontal',
      },
      {
        title: '对象可关联',
        description: '期刊、稿件、日程、附件、会议和项目之间可以互相关联，减少重复录入。',
        icon: 'tabler:link',
      },
      {
        title: 'AI 报告',
        description: '在需要判断投稿方向、整理材料或复盘记录时，用 AI 辅助生成更清晰的分析结果。',
        icon: 'tabler:report-analytics',
      },
      {
        title: '附件沉淀',
        description: '把投稿文件、修改稿、校样、通知邮件、会议资料等附件留在相关对象旁边。',
        icon: 'tabler:paperclip',
      },
      {
        title: '备份迁移',
        description: '为长期资料管理保留备份意识，降低换电脑、重装系统或版本升级时的资料焦虑。',
        icon: 'tabler:copy-check',
      },
      {
        title: '日程联动',
        description: '重要日期可以从对象详情页进入日程系统，写作计划和投稿节点都能回到月历中查看。',
        icon: 'tabler:calendar-stats',
      },
      {
        title: '快速检索',
        description: '当资料越来越多时，可以通过关键词、标签和对象关系快速找回过去的记录。',
        icon: 'tabler:search',
      },
      {
        title: '持续复盘',
        description: '投稿结果、退稿原因、返修经验和发表路径都能沉淀下来，成为下一次决策的依据。',
        icon: 'tabler:history',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- HighlightedPosts Widget ******* -->

  <BlogLatestPosts title="使用说明与更新日志" linkText="查看全部" />

  <!-- FAQs Widget ******************* -->

  <FAQs
    id="faq"
    title="常见问题"
    tagline="FAQ"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Article-Tool 的更新与维护情况？',
        description:
