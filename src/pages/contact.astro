---
import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: '联系我们',
};

const contactEmail = 'Quintuple0935@163.com';
const mailtoHref = `mailto:${contactEmail}?subject=${encodeURIComponent('Article-Tool 使用咨询')}`;

const contactMethods = [
  {
    icon: 'tabler:brand-wechat',
    title: '微信联系',
    label: '微信号：zonglangso974',
    description: '适合重度咨询、加入售后群等。添加时可备注 Article-Tool。',
  },
  {
    icon: 'tabler:mail',
    title: '邮箱联系',
    label: contactEmail,
    description: '适合激活、购买售后、隐私请求，以及需要附截图、日志或文件的正式反馈。',
    href: mailtoHref,
  },
  {
    icon: 'tabler:key',
    title: '激活与授权',
    label: '激活邮箱 / 订单号 / 授权提示',
    description: '遇到激活失败、换设备或授权找回时，请尽量附购买渠道、激活邮箱和页面提示。',
  },
  {
    icon: 'tabler:bug',
    title: '软件问题反馈',
    label: '版本号 / 系统版本 / 复现步骤',
    description: '请说明你做了什么、出现了什么结果、期望是什么；如果有报错或界面异常，附截图会更快定位。',
  },
];

const supportHints = [
  '激活问题：请写明购买渠道、激活邮箱、订单号或授权提示。',
  '软件错误：请附软件版本、系统版本、复现步骤和截图。',
  'AI 设置：请说明使用的是本地模型还是第三方服务，以及对应报错。',
  '隐私请求：请使用激活邮箱发送，便于确认请求来源。',
];
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden bg-slate-50 dark:bg-slate-950">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold tracking-wide text-accent dark:text-blue-300">支持与反馈</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">联系我们</h1>
        <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">
          无论是激活、购买、使用问题，还是隐私与服务条款咨询，都可以通过邮件或微信公众号联系。表单会调用你本机的邮箱客户端，不会把内容提交到网站服务器。
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-12 dark:bg-slate-900 lg:py-16">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 sm:px-6 lg:grid-cols-[1.1fr_0.9fr] lg:px-8">
      <div
        class="rounded-md border border-slate-200 bg-white p-6 shadow-lg shadow-slate-200/70 dark:border-slate-700 dark:bg-slate-950 dark:shadow-none sm:p-8"
      >
        <div class="mb-7 flex items-start gap-4">
          <div
            class="flex size-12 shrink-0 items-center justify-center rounded-md bg-blue-50 text-blue-700 dark:bg-blue-500/15 dark:text-blue-200"
          >
            <Icon name="tabler:mail" class="size-6" />
          </div>
          <div>
            <h2 class="text-2xl font-bold text-slate-950 dark:text-white">用邮件发送问题</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
              填写后点击发送，会先把内容按 UTF-8 编码整理进邮件正文，再打开你的默认邮箱客户端。
            </p>
          </div>
        </div>

        <form id="contact-mail-form" action={mailtoHref} class="space-y-5" data-contact-email={contactEmail}>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-sm font-semibold text-slate-800 dark:text-slate-100">称呼</label>
              <input
                id="name"
                name="称呼"
                type="text"
                required
                placeholder="怎么称呼你"
                class="mt-2 block w-full rounded-md border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-100 dark:border-slate-700 dark:bg-slate-900 dark:text-white dark:focus:ring-blue-500/20"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-slate-800 dark:text-slate-100">联系邮箱</label>
              <input
                id="email"
                name="联系邮箱"
                type="email"
                required
                placeholder="用于回复你"
                class="mt-2 block w-full rounded-md border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-100 dark:border-slate-700 dark:bg-slate-900 dark:text-white dark:focus:ring-blue-500/20"
              />
            </div>
          </div>

          <div>
            <label for="topic" class="block text-sm font-semibold text-slate-800 dark:text-slate-100">问题类型</label>
            <select
              id="topic"
              name="问题类型"
              class="mt-2 block w-full rounded-md border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-100 dark:border-slate-700 dark:bg-slate-900 dark:text-white dark:focus:ring-blue-500/20"
            >
              <option>激活与授权</option>
              <option>购买与售后</option>
              <option>软件使用问题</option>
              <option>Bug 反馈</option>
              <option>隐私或服务条款</option>
              <option>其他问题</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-slate-800 dark:text-slate-100">具体问题</label>
            <textarea
              id="message"
              name="具体问题"
              rows="7"
              required
              placeholder="请尽量写清楚问题背景、操作步骤、软件版本、系统版本，激活问题可附购买渠道或订单信息。"
              class="mt-2 block w-full rounded-md border border-slate-200 bg-white px-4 py-3 text-base text-slate-900 outline-none transition focus:border-blue-500 focus:ring-4 focus:ring-blue-100 dark:border-slate-700 dark:bg-slate-900 dark:text-white dark:focus:ring-blue-500/20"
            ></textarea>
          </div>

          <label
            class="flex gap-3 rounded-md border border-slate-200 bg-slate-50 p-4 text-sm leading-6 text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300"
          >
            <input
              type="checkbox"
              required
              class="mt-1 size-4 rounded border-slate-300 text-blue-600 focus:ring-blue-500"
            />
            <span>
              我理解该表单会调用本地邮箱客户端发送邮件，并同意按照
              <a href={getPermalink('/privacy')} class="font-semibold text-blue-700 hover:underline dark:text-blue-300"
                >隐私政策</a
              >
              处理我主动提供的信息。
            </span>
          </label>

          <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-md bg-blue-700 px-5 py-3 text-base font-semibold text-white shadow-sm transition hover:bg-blue-800 focus:outline-none focus:ring-4 focus:ring-blue-200 dark:bg-blue-600 dark:hover:bg-blue-500 dark:focus:ring-blue-500/30"
            >
              <Icon name="tabler:mail" class="mr-2 size-5" />
              用邮件发送
            </button>
            <a
              href={mailtoHref}
              class="inline-flex items-center justify-center rounded-md border border-slate-200 px-5 py-3 text-base font-semibold text-slate-700 transition hover:border-blue-300 hover:text-blue-700 dark:border-slate-700 dark:text-slate-200 dark:hover:border-blue-500 dark:hover:text-blue-200"
            >
              直接打开邮箱
            </a>
          </div>
        </form>
      </div>

      <aside class="space-y-5">
        <div
          class="rounded-md border border-blue-100 bg-white p-6 shadow-lg shadow-slate-200/70 dark:border-slate-700 dark:bg-slate-950 dark:shadow-none"
        >
          <div class="flex items-start gap-4">
            <div
              class="flex size-11 shrink-0 items-center justify-center rounded-md bg-blue-50 text-blue-700 dark:bg-blue-500/15 dark:text-blue-200"
            >
              <Icon name="tabler:message-circle" class="size-5" />
            </div>
            <div>
              <p class="text-sm font-semibold tracking-wide text-accent dark:text-blue-300">反馈提示</p>
              <h2 class="mt-1 text-2xl font-bold text-slate-950 dark:text-white">这样反馈会更快定位</h2>
              <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">
                先把关键信息放进邮件，可以少来回确认几次。
              </p>
            </div>
          </div>
          <div class="mt-5 space-y-3">
            {
              supportHints.map((hint, index) => (
                <div class="flex gap-3 rounded-md border border-slate-200 bg-slate-50 p-3 dark:border-slate-700 dark:bg-slate-900">
                  <div class="flex size-7 shrink-0 items-center justify-center rounded-full bg-white text-xs font-bold text-blue-700 shadow-sm dark:bg-slate-800 dark:text-blue-200">
                    {index + 1}
                  </div>
                  <p class="text-sm leading-6 text-slate-600 dark:text-slate-300">{hint}</p>
                </div>
              ))
            }
          </div>
        </div>

        <div class="rounded-md border border-blue-100 bg-blue-50 p-6 dark:border-blue-500/30 dark:bg-blue-500/10">
          <p class="text-sm font-semibold text-blue-800 dark:text-blue-200">邮箱</p>
          <a
            href={mailtoHref}
            class="mt-1 block break-all text-xl font-bold text-slate-950 hover:underline dark:text-white"
          >
            {contactEmail}
          </a>
          <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
            这里目前使用
            `mailto`，所以是否能自动弹出写信窗口取决于你的浏览器和系统邮箱设置。若表单无法打开邮箱，可以直接复制这个邮箱地址发送。
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="bg-slate-50 py-14 dark:bg-slate-950 lg:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-accent dark:text-blue-300">联系渠道</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white">选择合适的联系入口</h2>
        <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300">
          简单咨询可以走微信；激活、售后、隐私请求和需要定位的问题，建议走邮箱，方便核对信息、附截图，也便于后续留痕。
        </p>
      </div>

      <div class="mt-9 grid gap-5 md:grid-cols-2">
        {
          contactMethods.map((item) => (
            <div class="group rounded-md border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-lg hover:shadow-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-blue-500/40 dark:hover:shadow-none">
              <div class="flex gap-4">
                <div class="flex size-12 shrink-0 items-center justify-center rounded-md bg-slate-100 text-slate-800 transition group-hover:bg-blue-50 group-hover:text-blue-700 dark:bg-slate-800 dark:text-slate-100 dark:group-hover:bg-blue-500/15 dark:group-hover:text-blue-200">
                  <Icon name={item.icon} class="size-6" />
                </div>
                <div>
                  <h3 class="text-xl font-bold text-slate-950 dark:text-white">{item.title}</h3>
                  {item.href ? (
                    <a
                      href={item.href}
                      class="mt-1 block break-all text-base font-semibold text-blue-700 hover:underline dark:text-blue-300"
                    >
                      {item.label}
                    </a>
                  ) : (
                    <p class="mt-1 text-base font-semibold text-blue-700 dark:text-blue-300">{item.label}</p>
                  )}
                  <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">{item.description}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<script>
  const contactForm = document.querySelector('#contact-mail-form');

  contactForm?.addEventListener('submit', (event) => {
    event.preventDefault();

    if (!(contactForm instanceof HTMLFormElement) || !contactForm.reportValidity()) {
      return;
    }

    const getFieldValue = (selector: string) => {
      const field = document.querySelector(selector);

      if (
        field instanceof HTMLInputElement ||
        field instanceof HTMLSelectElement ||
        field instanceof HTMLTextAreaElement
      ) {
        return field.value.trim();
      }

      return '';
    };

    const contactEmail = contactForm.dataset.contactEmail;
    const name = getFieldValue('#name');
    const replyEmail = getFieldValue('#email');
    const topic = getFieldValue('#topic');
    const message = getFieldValue('#message');

    if (!contactEmail) {
      return;
    }

    const subject = `Article-Tool 使用咨询：${topic || '联系支持'}`;
    const body = [
      '你好，我想咨询 Article-Tool 相关问题。',
      '',
      `称呼：${name || ''}`,
      `联系邮箱：${replyEmail || ''}`,
      `问题类型：${topic || ''}`,
      '',
      '具体问题：',
      message || '',
      '',
      '补充信息：',
      '- 软件版本：',
      '- 系统版本：',
      '- 购买渠道 / 订单号：',
    ].join('\n');

    window.location.href = `mailto:${contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(
      body
    )}`;
  });
</script>
