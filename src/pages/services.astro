---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

import { Icon } from 'astro-icon/components';

import Layout from '~/layouts/PageLayout.astro';

type UpdateData = {
  version: string;
  title: string;
  releaseDate: string;
  channelLabel: string;
  publicDownloadVersion: string;
  notes: string[];
  downloads: Record<string, string>;
  pageUrl?: string;
  force: boolean;
};

type ChangelogEntry = {
  date: string;
  version: string;
  title: string;
  tags: string[];
  text: string;
};

type ChangelogData = {
  product: string;
  subtitle: string;
  summary: string;
  updates: ChangelogEntry[];
};

// Edit this list to maintain the standalone planned updates section.
const plannedUpdates = [
  {
    label: 'AI对话',
    title: '不同对象的AI交谈功能',
    description: '对每库的对象页面里增加更为细致的AI功能，可以针对不同对象的具体信息进行AI聊天。',
    icon: 'tabler:folders',
  },
  {
    label: 'AI建议',
    title: 'AI建议的优化',
    description: '（1）AI 建议依据抽屉。每条 AI 建议下面点“查看依据”时，不只是展开一句话，而是显示它用了哪些资料。（2）每一轮AI建议的进一步优化与保存，让用户用低成本反馈把下一轮建议拉准。',
    icon: 'tabler:timeline-event',
  },
  {
    label: '期刊辅助',
    title: '期刊的辅助增强',
    description: '给期刊页加一个“过刊/近年发文”小面板：高频栏目、常见题型、材料类型、时间段、方法词。',
    icon: 'tabler:sparkles',
  },
];

const updateData = JSON.parse(
  readFileSync(join(process.cwd(), 'public/article-tool/update.json'), 'utf-8')
) as UpdateData;

const changelogData = JSON.parse(
  readFileSync(join(process.cwd(), 'public/article-tool/changelog-data.json'), 'utf-8')
) as ChangelogData;

const metadata = {
  title: '下载更新',
};

const updates = [...changelogData.updates].reverse();
const downloadEntries = Object.entries(updateData.downloads);

const splitUpdateText = (text: string) => {
  const parts = text
    .split(/(?=（\d+）)/)
    .map((item) => item.trim())
    .filter(Boolean);

  return parts.length > 1 ? parts : [text];
};

const tagStyles: Record<string, string> = {
  BUG修复: 'bg-rose-50 text-rose-700 ring-rose-100 dark:bg-rose-500/10 dark:text-rose-200 dark:ring-rose-500/20',
  功能增加: 'bg-blue-50 text-blue-700 ring-blue-100 dark:bg-blue-500/10 dark:text-blue-200 dark:ring-blue-500/20',
  视觉升级:
    'bg-violet-50 text-violet-700 ring-violet-100 dark:bg-violet-500/10 dark:text-violet-200 dark:ring-violet-500/20',
  基础框架: 'bg-slate-100 text-slate-700 ring-slate-200 dark:bg-slate-800 dark:text-slate-200 dark:ring-slate-700',
  压力测试: 'bg-amber-50 text-amber-700 ring-amber-100 dark:bg-amber-500/10 dark:text-amber-200 dark:ring-amber-500/20',
  正式版:
    'bg-emerald-50 text-emerald-700 ring-emerald-100 dark:bg-emerald-500/10 dark:text-emerald-200 dark:ring-emerald-500/20',
};

const shouldShowInlineVersion = (item: ChangelogEntry) => {
  const title = item.title.toLowerCase().replace(/\s+/g, '');
  const compactTitle = title.replace(/\./g, '');
  const version = item.version.toLowerCase().replace(/^v/, '');
  const compactVersion = version.replace(/\./g, '');

  return !title.includes(version) && !compactTitle.includes(compactVersion);
};
---

<Layout metadata={metadata}>
  <section class="relative overflow-hidden bg-slate-50 dark:bg-slate-950">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-blue-300 to-transparent"></div>
    <div
      class="mx-auto grid max-w-6xl items-stretch gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:px-8 lg:py-20"
    >
      <div class="flex h-full max-w-3xl flex-col">
        <p class="text-sm font-semibold tracking-wide text-accent dark:text-blue-300">版本中心</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 dark:text-white md:text-5xl">
          Article-Tool 下载更新
        </h1>
        <p class="mt-5 text-lg leading-8 text-slate-600 dark:text-slate-300">{changelogData.summary}</p>
        <div
          id="download"
          class="mt-8 rounded-md border border-blue-100 bg-gradient-to-br from-blue-50 via-white to-slate-50 p-4 shadow-sm dark:border-blue-500/20 dark:from-blue-500/10 dark:via-slate-900 dark:to-slate-950 sm:p-5"
        >
          <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="text-sm font-semibold text-blue-700 dark:text-blue-300">下载渠道</p>
              <h2 class="mt-1 text-2xl font-bold tracking-tight text-slate-950 dark:text-white">选择一个网盘入口</h2>
            </div>
            <p class="text-sm leading-6 text-slate-500 dark:text-slate-400">提取码和文件版本以网盘页面显示为准。</p>
          </div>

          <div class:list={['mt-5 grid gap-3', downloadEntries.length > 1 && 'sm:grid-cols-2']}>
            {
              downloadEntries.map(([name, href]) => (
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between gap-4 rounded-md border border-slate-200 bg-white px-4 py-4 transition hover:-translate-y-0.5 hover:border-blue-300 hover:bg-blue-50 hover:shadow-sm dark:border-slate-700 dark:bg-slate-900 dark:hover:border-blue-500/50 dark:hover:bg-blue-500/10"
                >
                  <span class="flex min-w-0 items-center gap-3">
                    <span class="flex size-10 shrink-0 items-center justify-center rounded-md bg-blue-50 text-blue-700 shadow-sm dark:bg-slate-800 dark:text-blue-200">
                      <Icon name="tabler:cloud-download" class="size-5" />
                    </span>
                    <span>
                      <span class="block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                        网盘下载
                      </span>
                      <span class="mt-0.5 block text-xl font-bold text-slate-950 dark:text-white">{name}</span>
                    </span>
                  </span>
                  <Icon
                    name="tabler:external-link"
                    class="size-5 shrink-0 text-blue-700 transition group-hover:translate-x-0.5 dark:text-blue-300"
                  />
                </a>
              ))
            }
          </div>

          <div
            class="mt-4 flex flex-col gap-3 rounded-md border border-blue-100 bg-white/75 px-4 py-3 text-sm leading-6 text-slate-600 dark:border-blue-500/20 dark:bg-blue-500/10 dark:text-slate-300 sm:flex-row sm:items-center"
          >
            <Icon name="tabler:info-circle" class="size-5 shrink-0 text-blue-700 dark:text-blue-300" />
            <span>下载后可先使用免费版确认工作流；需要长期整理、扩展字段和持续追踪投稿流程时，再购买买断授权。</span>
          </div>
        </div>
      </div>

      <div
        class="flex h-full flex-col rounded-md border border-blue-100 bg-white p-6 shadow-lg shadow-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:shadow-none sm:p-7"
      >
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-sm font-semibold text-blue-700 dark:text-blue-300">{updateData.channelLabel}</p>
            <h2 class="mt-1 text-3xl font-bold tracking-tight text-slate-950 dark:text-white">{updateData.title}</h2>
          </div>
          <div
            class="flex size-14 shrink-0 items-center justify-center rounded-md bg-blue-50 text-blue-700 dark:bg-blue-500/15 dark:text-blue-200"
          >
            <Icon name="tabler:sparkles" class="size-7" />
          </div>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <div class="rounded-md border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-950">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Version</p>
            <p class="mt-1 text-2xl font-bold text-slate-950 dark:text-white">{updateData.version}</p>
          </div>
          <div class="rounded-md border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-950">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Date</p>
            <p class="mt-1 text-2xl font-bold text-slate-950 dark:text-white">{updateData.releaseDate}</p>
          </div>
        </div>

        <div class="mt-6 grid flex-1 auto-rows-fr gap-3">
          {
            updateData.notes.map((note) => (
              <div class="flex h-full gap-3 rounded-md bg-blue-50/70 p-4 text-sm leading-6 text-slate-700 dark:bg-blue-500/10 dark:text-slate-200">
                <Icon name="tabler:circle-dot" class="mt-0.5 size-5 shrink-0 text-blue-700 dark:text-blue-300" />
                <span>{note}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section
    id="planned-updates"
    class="border-y border-slate-200 bg-slate-50 py-14 dark:border-slate-800 dark:bg-slate-950 lg:py-16"
  >
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
        <div
          class="rounded-md border border-blue-100 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-900 sm:p-7"
        >
          <p class="text-sm font-semibold tracking-wide text-accent dark:text-blue-300">开发计划</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white">准备更新内容</h2>
          <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300">
            这里用于说明 Article-Tool 正在准备或计划优化的方向。具体功能、发布时间和最终实现方式，仍以正式发布版本为准。
          </p>
          <div
            class="mt-6 rounded-md bg-blue-50 p-4 text-sm leading-6 text-blue-900 ring-1 ring-blue-100 dark:bg-blue-500/10 dark:text-blue-100 dark:ring-blue-500/20"
          >
            <div class="flex gap-3">
              <Icon name="tabler:info-circle" class="mt-0.5 size-5 shrink-0 text-blue-700 dark:text-blue-300" />
              <p>更新计划会根据实际开发进度和用户反馈调整，已发布内容请以当前版本说明与历史更新记录为准。</p>
            </div>
          </div>
        </div>

        <div class="grid gap-4">
          {
            plannedUpdates.map((item, index) => (
              <article class="group rounded-md border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-lg hover:shadow-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-blue-500/40 dark:hover:shadow-none">
                <div class="flex gap-4">
                  <div class="flex flex-col items-center">
                    <span class="flex size-12 shrink-0 items-center justify-center rounded-md bg-blue-50 text-blue-700 transition group-hover:bg-blue-700 group-hover:text-white dark:bg-blue-500/15 dark:text-blue-200 dark:group-hover:bg-blue-500 dark:group-hover:text-white">
                      <Icon name={item.icon} class="size-6" />
                    </span>
                    {index < plannedUpdates.length - 1 && (
                      <span class="mt-3 h-full min-h-10 w-px bg-slate-200 dark:bg-slate-700" />
                    )}
                  </div>
                  <div class="min-w-0 flex-1 pb-1">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-slate-200 dark:bg-slate-800 dark:text-slate-300 dark:ring-slate-700">
                        {item.label}
                      </span>
                      <span class="text-xs font-semibold text-slate-400 dark:text-slate-500">
                        计划更新 {String(index + 1).padStart(2, '0')}
                      </span>
                    </div>
                    <h3 class="mt-3 text-xl font-bold tracking-tight text-slate-950 dark:text-white">{item.title}</h3>
                    <p class="mt-2 text-sm leading-7 text-slate-600 dark:text-slate-300">{item.description}</p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="changelog" class="bg-white py-14 dark:bg-slate-900 lg:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
        <div class="lg:sticky lg:top-28 lg:self-start">
          <p class="text-sm font-semibold tracking-wide text-accent dark:text-blue-300">更新记录</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-950 dark:text-white">历史更新记录</h2>
          <p class="mt-4 text-base leading-7 text-slate-600 dark:text-slate-300">
            共整理 {changelogData.updates.length} 条版本记录。时间线按最新在前排列，方便快速查看最近修复和新增功能。
          </p>
        </div>

        <ol class="relative space-y-5 border-l border-slate-200 pl-6 dark:border-slate-700">
          {
            updates.map((item, index) => (
              <li class="relative">
                <div
                  class:list={[
                    'absolute -left-[31px] top-6 flex size-3 rounded-full ring-4',
                    index === 0
                      ? 'bg-blue-700 ring-blue-100 dark:bg-blue-300 dark:ring-blue-500/20'
                      : 'bg-slate-300 ring-white dark:bg-slate-600 dark:ring-slate-900',
                  ]}
                />
                <article class="rounded-md border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-950 sm:p-6">
                  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                    <div>
                      <p class="text-sm font-semibold text-slate-500 dark:text-slate-400">{item.date}</p>
                      <h3 class="mt-1 text-2xl font-bold text-slate-950 dark:text-white">
                        {item.title}
                        {shouldShowInlineVersion(item) && (
                          <span class="ml-2 text-base font-semibold text-blue-700 dark:text-blue-300">
                            v{item.version}
                          </span>
                        )}
                      </h3>
                    </div>
                    <div class="flex flex-wrap gap-2">
                      {item.tags.map((tag) => (
                        <span
                          class:list={[
                            'inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ring-1',
                            tagStyles[tag] ??
                              'bg-slate-100 text-slate-700 ring-slate-200 dark:bg-slate-800 dark:text-slate-200 dark:ring-slate-700',
                          ]}
                        >
                          {tag}
                        </span>
                      ))}
                    </div>
                  </div>

                  <div class="mt-5 space-y-3">
                    {splitUpdateText(item.text).map((text) => (
                      <p class="rounded-md bg-slate-50 px-4 py-3 text-sm leading-7 text-slate-600 dark:bg-slate-900 dark:text-slate-300">
                        {text}
                      </p>
                    ))}
                  </div>
                </article>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>
</Layout>
