---
// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-fangsong:
      FangSong, 'FangSong SC', STFangsong, 'STFangsong', 'FangSong_GB2312', '仿宋', '仿宋_GB2312', 'Songti SC', serif;
    --aw-font-sans: var(--aw-font-fangsong);
    --aw-font-serif: var(--aw-font-fangsong);
    --aw-font-heading: var(--aw-font-fangsong);

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: var(--aw-font-fangsong);
    --aw-font-serif: var(--aw-font-fangsong);
    --aw-font-heading: var(--aw-font-fangsong);

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(1 84 207);
    --aw-color-accent: rgb(109 40 217);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: black;
      color: snow;
    }
  }

  html,
  body,
  button,
  input,
  textarea,
  select {
    font-family: var(--aw-font-sans);
  }

  .font-heading,
  .font-serif,
  .font-sans,
  .prose,
  .prose :where(h1, h2, h3, h4, h5, h6, p, li, blockquote, figcaption, table, code) {
    font-family: var(--aw-font-sans);
  }
</style>
